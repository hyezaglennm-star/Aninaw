<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#F8F6F2"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="#DFD9CF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="76dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginEnd="14dp"
            app:cardBackgroundColor="#F3EEE7"
            app:cardCornerRadius="15dp"
            app:cardElevation="0dp"
            app:strokeColor="#E0D9CF"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/ivToolIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/ic_reflect"
                android:contentDescription="@null" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvToolTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Breathing"
                android:textColor="#4A4A44"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvToolTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="March 13, 2026 • 8:10 PM"
                android:textColor="#6B6B65"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvToolMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="• 30 sec • Completed"
                android:textColor="#8C877F"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>