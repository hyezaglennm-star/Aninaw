<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootCalmTools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F1EC">

    <include
        layout="@layout/view_back_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="78dp"
        android:paddingHorizontal="22dp"
        android:paddingTop="18dp"
        android:text="@string/calm_tools_title"
        android:textColor="#4A4A44"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="22dp"
        android:text="@string/calm_tools_subtitle"
        android:textColor="#6B6B65"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <ScrollView
        android:id="@+id/scrollTools"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <LinearLayout
            android:id="@+id/panelTools"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:paddingStart="4dp"
                android:text="Short practices"
                android:textColor="#7A7A74"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- 1) Stretch -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStretch"
                style="@style/CalmCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#F8F6F2"
                app:strokeColor="#DFD9CF"
                app:strokeWidth="1dp">

                <LinearLayout
                    style="@style/CalmCardInnerRow"
                    android:minHeight="76dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/badgeStretch"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="#EFE8DE"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#DDD4C8"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/iconStretch"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.95"
                            android:contentDescription="@string/cd_stretch"
                            android:padding="10dp"
                            android:src="@drawable/ic_stretch" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvStretchTitle"
                            style="@style/CalmCardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tool_stretch_title" />

                        <TextView
                            android:id="@+id/tvStretchSub"
                            style="@style/CalmCardSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Release tension in under a minute"
                            android:textColor="#7E7A73" />

                        <TextView
                            android:id="@+id/tvStretchMeta"
                            style="@style/CalmCardMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="• 1 minute"
                            android:textColor="#8C877F"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/chevronStretch"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.5"
                        android:contentDescription="@string/cd_open_stretch"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 2) Grounding -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrounding"
                style="@style/CalmCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#F8F6F2"
                app:strokeColor="#DFD9CF"
                app:strokeWidth="1dp">

                <LinearLayout
                    style="@style/CalmCardInnerRow"
                    android:minHeight="76dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/badgeGrounding"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="#F3EEE7"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#E0D9CF"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/iconGrounding"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.95"
                            android:contentDescription="@string/cd_grounding"
                            android:padding="10dp"
                            android:src="@drawable/ic_ground" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGroundingTitle"
                            style="@style/CalmCardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tool_ground_title" />

                        <TextView
                            android:id="@+id/tvGroundingSub"
                            style="@style/CalmCardSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Return to the present through your senses"
                            android:textColor="#7E7A73" />

                        <TextView
                            android:id="@+id/tvGroundingMeta"
                            style="@style/CalmCardMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="• 1 minute"
                            android:textColor="#8C877F"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/chevronGrounding"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.5"
                        android:contentDescription="@string/cd_open_grounding"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 3) Breathing -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBreathing"
                style="@style/CalmCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#F8F6F2"
                app:strokeColor="#DFD9CF"
                app:strokeWidth="1dp">

                <LinearLayout
                    style="@style/CalmCardInnerRow"
                    android:minHeight="76dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/badgeBreathing"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="#F3EEE7"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#E0D9CF"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/iconBreathing"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.95"
                            android:contentDescription="@string/cd_breathing"
                            android:padding="10dp"
                            android:src="@drawable/ic_breath" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBreathingTitle"
                            style="@style/CalmCardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tool_breathe_title" />

                        <TextView
                            android:id="@+id/tvBreathingSub"
                            style="@style/CalmCardSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A quick nervous system reset"
                            android:textColor="#7E7A73" />

                        <TextView
                            android:id="@+id/tvBreathingMeta"
                            style="@style/CalmCardMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="• 30 seconds"
                            android:textColor="#8C877F"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/chevronBreathing"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.5"
                        android:contentDescription="@string/cd_open_breathing"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 4) Journal -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJournal"
                style="@style/CalmCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#F8F6F2"
                app:strokeColor="#DFD9CF"
                app:strokeWidth="1dp">

                <LinearLayout
                    style="@style/CalmCardInnerRow"
                    android:minHeight="76dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/badgeJournal"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="#F3EEE7"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#E0D9CF"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/iconJournal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.95"
                            android:contentDescription="@string/cd_journal"
                            android:padding="10dp"
                            android:src="@drawable/ic_journal" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvJournalTitle"
                            style="@style/CalmCardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tool_journal_title" />

                        <TextView
                            android:id="@+id/tvJournalSub"
                            style="@style/CalmCardSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="One honest paragraph. No pressure"
                            android:textColor="#7E7A73" />

                        <TextView
                            android:id="@+id/tvJournalMeta"
                            style="@style/CalmCardMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="• 1 minute"
                            android:textColor="#8C877F"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/chevronJournal"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.5"
                        android:contentDescription="@string/cd_open_journal"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 5) CBT -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCbt"
                style="@style/CalmCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#F8F6F2"
                app:strokeColor="#DFD9CF"
                app:strokeWidth="1dp">

                <LinearLayout
                    style="@style/CalmCardInnerRow"
                    android:minHeight="76dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/badgeCbt"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="14dp"
                        app:cardBackgroundColor="#F3EEE7"
                        app:cardCornerRadius="15dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#E0D9CF"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/iconCbt"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.95"
                            android:contentDescription="@string/cd_cbt_reflection"
                            android:padding="10dp"
                            android:src="@drawable/ic_reflect" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCbtTitle"
                            style="@style/CalmCardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tool_cbt_title" />

                        <TextView
                            android:id="@+id/tvCbtSub"
                            style="@style/CalmCardSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gently examine what you're telling yourself"
                            android:textColor="#7E7A73" />

                        <TextView
                            android:id="@+id/tvCbtMeta"
                            style="@style/CalmCardMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="• 2 minutes"
                            android:textColor="#8C877F"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/chevronCbt"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.5"
                        android:contentDescription="@string/cd_open_cbt"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>