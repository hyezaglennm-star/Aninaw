<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Base fills the pose canvas -->
    <ImageView
        android:id="@+id/liwanagBase"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/body_looking_left"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Shadow stays under Liwanag, scaled to body width -->
    <ImageView
        android:id="@+id/liwanagShadow"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:src="@drawable/shadow_soft"
        android:alpha="0.35"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="6dp"
        app:layout_constraintStart_toStartOf="@id/liwanagBase"
        app:layout_constraintEnd_toEndOf="@id/liwanagBase"
        app:layout_constraintBottom_toBottomOf="@id/liwanagBase" />

    <!-- Leaf: position with bias (stable), micro-tune with translation (still animatable) -->
    <ImageView
        android:id="@+id/liwanagLeaf"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:src="@drawable/liwanag_leaf"
        android:rotation="20"
        android:alpha="1"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="@id/liwanagBase"
        app:layout_constraintEnd_toEndOf="@id/liwanagBase"
        app:layout_constraintTop_toTopOf="@id/liwanagBase"
        app:layout_constraintBottom_toBottomOf="@id/liwanagBase"
        app:layout_constraintHorizontal_bias="0.72"
        app:layout_constraintVertical_bias="0.22"
        android:translationX="8dp"
        android:translationY="6dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
