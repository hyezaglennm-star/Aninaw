<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aninaw_bg_top">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- HEADER -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Go back"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/cormorant_garamond_semibold"
                android:text="Welcome back."
                android:textColor="@color/aninaw_text_primary"
                android:textSize="30sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnBack" />

            <!-- CALENDAR STRIP -->
            <LinearLayout
                android:id="@+id/calendarStrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

            <!-- TODAY PAGE HEADER -->
            <TextView
                android:id="@+id/tvMyJournalHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/cormorant_garamond_semibold"
                android:text="Today’s page"
                android:textColor="@color/aninaw_text_primary"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/calendarStrip" />

            <TextView
                android:id="@+id/tvSeeAllMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/inter_regular"
                android:paddingStart="6dp"
                android:paddingTop="6dp"
                android:paddingEnd="6dp"
                android:paddingBottom="6dp"
                android:text="Past reflections"
                android:textColor="@color/aninaw_text_secondary"
                android:textSize="13sp"
                app:layout_constraintBaseline_toBaselineOf="@id/tvMyJournalHeader"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- MAIN JOURNAL CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMorning"
                android:layout_width="0dp"
                android:layout_height="212dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#E8BE57"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toStartOf="@id/cardCoreFeelings"
                app:layout_constraintHorizontal_weight="2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvMyJournalHeader"
                app:strokeColor="#10FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:id="@+id/tvMorningTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond_semibold"
                        android:gravity="center"
                        android:text="Start with a gentle page"
                        android:textColor="#3E2B1F"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/tvMorningBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/inter_regular"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:maxLines="3"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="Begin with a quiet reflection on what feels present for you right now."
                        android:textColor="#5D463A"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CORE FEELINGS TAB -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCoreFeelings"
                android:layout_width="64dp"
                android:layout_height="212dp"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#E7E5E2"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvMyJournalHeader"
                app:strokeColor="#12FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <!-- subtle leaf icon -->
                    <ImageView
                        android:id="@+id/imgCoreFeelingsIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_sprout"
                        android:alpha="0.85"
                        android:layout_marginBottom="10dp"
                        app:tint="#6F6964" />

                    <!-- rotated label -->
                    <TextView
                        android:id="@+id/tvCoreFeelings"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:rotation="270"
                        android:fontFamily="@font/cormorant_garamond_semibold"
                        android:text="Core feelings"
                        android:textColor="#6F6964"
                        android:textSize="17sp"
                        android:gravity="center"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- REFLECTION PROMPTS HEADER -->
            <TextView
                android:id="@+id/tvSuggestedHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/cormorant_garamond_semibold"
                android:text="A reflection for today"
                android:textColor="@color/aninaw_text_primary"
                android:textSize="22sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardMorning" />


            <!-- TODAY'S REFLECTION CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPromptOne"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="164dp"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#F8F2EF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvSuggestedHeader"
                app:strokeColor="#12FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pause and notice"
                        android:textColor="#5B5049"
                        android:textSize="20sp"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/cormorant_garamond_semibold"/>

                    <TextView
                        android:id="@+id/tvPromptOneBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="4dp"
                        android:text="What is one feeling or thought that has been quietly asking for your attention today?"
                        android:textColor="#6F625B"
                        android:textSize="15sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- QUICK ACTIONS ROW -->
            <LinearLayout
                android:id="@+id/quickActionsRow"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:weightSum="2"
                app:layout_constraintTop_toBottomOf="@id/cardPromptOne"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardQuickPause"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#E6EEF2"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#12FFFFFF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_breath"
                            app:tint="#5A6D76"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Pause"
                            android:fontFamily="@font/cormorant_garamond_semibold"
                            android:textSize="18sp"
                            android:textColor="#5A6D76"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardQuickIntention"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#F2E6DD"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#12FFFFFF"
                    app:strokeWidth="1dp">
                     <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_reflect"
                            app:tint="#7D655C"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Intention"
                            android:fontFamily="@font/cormorant_garamond_semibold"
                            android:textSize="18sp"
                            android:textColor="#7D655C"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="32dp"
                app:layout_constraintTop_toBottomOf="@id/quickActionsRow"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>