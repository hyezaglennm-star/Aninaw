<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="14dp"
    android:paddingBottom="18dp">

    <!-- little handle -->
    <View
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:id="@+id/tvSheetLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Session 7"
        android:textSize="13sp"
        android:textColor="@color/aninaw_text_secondary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Take one slow breath."
        android:textSize="18sp"
        android:textColor="@color/aninaw_text_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSheetDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Notice the air entering and leaving."
        android:textSize="14sp"
        android:textColor="@color/aninaw_text_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSheetClose"
            style="@style/CheckInButtonStyle"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Close" />

        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSheetBegin"
            style="@style/CheckInButtonStyle"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Begin" />
    </LinearLayout>

</LinearLayout>