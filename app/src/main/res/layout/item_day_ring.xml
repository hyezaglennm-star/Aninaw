<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="92dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/imgDayRing"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:contentDescription="Day ring"
        android:src="@drawable/ic_tree_rings" />

    <TextView
        android:id="@+id/tvDayLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/cormorant_garamond_medium"
        android:text="Mon"
        android:textColor="#5D544D"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvDayCaption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/inter_regular"
        android:gravity="center"
        android:text="A calm moment."
        android:textColor="#7A7068"
        android:textSize="12sp" />
</LinearLayout>