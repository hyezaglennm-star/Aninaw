            android:background="@drawable/bg_session_tile"/>

        <TextView
            android:id="@+id/tile20"
            style="@style/SessionTileNumber"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            app:layout_columnWeight="1"
            app:layout_gravity="fill"
            android:gravity="center"
            android:text="20"
            android:textColor="@color/aninaw_text_secondary"
            android:background="@drawable/bg_session_tile"/>

        <TextView
            android:id="@+id/tile21"
            style="@style/SessionTileNumber"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            app:layout_columnWeight="1"
            app:layout_gravity="fill"
            android:gravity="center"
            android:text="21"
            android:textColor="@color/aninaw_text_secondary"
            android:background="@drawable/bg_session_tile"/>

    </androidx.gridlayout.widget.GridLayout>

    <!-- CTA (kept hidden since bottom sheet handles start) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBeginPractice"
        style="@style/CheckInButtonStyle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Begin practice"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/gridSessions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"/>

</androidx.constraintlayout.widget.ConstraintLayout>