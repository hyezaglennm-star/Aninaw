            android:layout_margin="6dp"
            app:layout_columnWeight="1"
            app:layout_gravity="fill"
            android:gravity="center"
            android:text="4"
            android:background="@drawable/bg_session_tile_done"/>

        <TextView
            android:id="@+id/tile5"
            style="@style/SessionTileNumber"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            app:layout_columnWeight="1"
            app:layout_gravity="fill"
            android:gravity="center"
            android:text="5"
            android:background="@drawable/bg_session_tile_done"/>

        <TextView
            android:id="@+id/tile6"
            style="@style/SessionTileNumber"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            app:layout_columnWeight="1"
            app:layout_gravity="fill"
            android:gravity="center"
            android:text="6"
            android:background="@drawable/bg_session_tile_done"/>

        <!-- CURRENT -->
        <TextView
            android:id="@+id/tile7"
            style="@style/SessionTileNumber"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            app:layout_columnWeight="1"
            app:layout_gravity="fill"
            android:gravity="center"
            android:text="7"
            android:textColor="@color/purple_700"
            android:background="@drawable/bg_session_tile_current"/>

        <!-- UPCOMING (quieter text) -->
        <TextView
            android:id="@+id/tile8"
            style="@style/SessionTileNumber"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            app:layout_columnWeight="1"
            app:layout_gravity="fill"
            android:gravity="center"
            android:text="8"
            android:textColor="@color/aninaw_text_secondary"
            android:background="@drawable/bg_session_tile"/>

        <TextView
            android:id="@+id/tile9"
            style="@style/SessionTileNumber"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="6dp"
            app:layout_columnWeight="1"
            app:layout_gravity="fill"
