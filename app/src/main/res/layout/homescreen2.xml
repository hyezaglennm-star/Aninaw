<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rootHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home_soft">

        <!-- Main Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/sceneCanvas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_home"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:paddingStart="24dp"
            android:paddingTop="22dp"
            android:paddingEnd="24dp"
            android:paddingBottom="140dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/contentHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Header: Menu & Greeting -->
                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_menu_pill"
                    android:clickable="true"
                    android:contentDescription="Menu"
                    android:focusable="true"
                    android:padding="12dp"
                    android:src="@drawable/ic_menu"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/greetingGroup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/btnMenu"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond_semibold"
                        android:text="Good evening,"
                        android:textColor="#544840"
                        android:textSize="31sp" />

                    <TextView
                        android:id="@+id/tvGreetingSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/cormorant_garamond_medium"
                        android:text="Pause for one slow breath."
                        android:textColor="#6B5E58"
                        android:textSize="18sp" />
                </LinearLayout>

                <!-- Tree hero: half-screen emphasis -->
                <FrameLayout
                    android:id="@+id/layoutTreeHero"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:layout_constraintTop_toBottomOf="@id/greetingGroup"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHeight_default="percent"
                    app:layout_constraintHeight_percent="0.50">

                    <com.aninaw.views.HybridTreeView
                        android:id="@+id/hybridTreeView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center_horizontal|bottom"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="76dp" />

                    <TextView
                        android:id="@+id/tvTreeHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal|bottom"
                        android:layout_marginBottom="28dp"
                        android:fontFamily="@font/cormorant_garamond_medium"
                        android:text="Tap the tree to see your days."
                        android:textColor="#5F544D"
                        android:textSize="18sp" />
                </FrameLayout>

                <!-- Placeholder for liwanagPoseContainer (hidden or small) -->
                <FrameLayout
                    android:id="@+id/liwanagPoseContainer"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Mood summary: lighter so the tree remains primary -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardBackgroundColor="#F8F1EE"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#10FFFFFF"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/layoutTreeHero"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="76dp"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="14dp">

                        <ImageView
                            android:id="@+id/imgMood"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Mood icon"
                            android:alpha="0.90"
                            android:src="@drawable/ic_sprout" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvMoodTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/cormorant_garamond_semibold"
                                android:text="Mood: Calm"
                                android:textColor="#554942"
                                android:textSize="19sp" />

                            <TextView
                                android:id="@+id/tvMoodBody"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:fontFamily="@font/inter_regular"
                                android:text="You wrote about school today."
                                android:textColor="#80736D"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Reflection prompt -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardReflection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#F8F2EF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="1.5dp"
                    app:strokeColor="#10FFFFFF"
                    app:strokeWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/cardMood"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="62dp"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="14dp">

                        <TextView
                            android:id="@+id/tvReflectionPrompt"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/cormorant_garamond_medium"
                            android:text="If you’d like, write a short reflection."
                            android:textColor="#5B5049"
                            android:textSize="17sp" />

                        <ImageView
                            android:id="@+id/imgReflectionArrow"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:alpha="0.72"
                            android:contentDescription="Open reflection"
                            android:src="@drawable/ic_chevron_right_soft" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Affirmation text: more legible -->
                <TextView
                    android:id="@+id/tvAffirmation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:alpha="0.94"
                    android:fontFamily="@font/cormorant_garamond_medium"
                    android:gravity="center"
                    android:text="You showed up today. That matters."
                    android:textColor="#6F625B"
                    android:textSize="17sp"
                    app:layout_constraintTop_toBottomOf="@id/cardReflection"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvDebugDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.7"
                    android:fontFamily="@font/inter_regular"
                    android:gravity="center"
                    android:text="Day 1 of 21 (tap to change)"
                    android:textColor="#6F625B"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tvAffirmation"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <Space
                    android:id="@+id/spaceBottom"
                    android:layout_width="0dp"
                    android:layout_height="12dp"
                    app:layout_constraintTop_toBottomOf="@id/tvDebugDay"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Bottom navigation -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBottomNav"
            android:layout_width="0dp"
            android:layout_height="88dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#F6EFEC"
            app:cardCornerRadius="30dp"
            app:cardElevation="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:strokeColor="#10FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="4">

                <LinearLayout
                    android:id="@+id/navHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/imgNavHome"
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:alpha="0.92"
                        android:contentDescription="Home"
                        android:src="@drawable/outline_circle_24" />

                    <TextView
                        android:id="@+id/tvNavHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Home"
                        android:textColor="#5A5049"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navWrite"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/imgNavWrite"
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:alpha="0.78"
                        android:contentDescription="Write"
                        android:src="@drawable/outline_eco_24" />

                    <TextView
                        android:id="@+id/tvNavWrite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Write"
                        android:textColor="#847972"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navDays"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/imgNavDays"
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:alpha="0.78"
                        android:contentDescription="Your Days"
                        android:src="@drawable/outline_clear_day_24" />

                    <TextView
                        android:id="@+id/tvNavDays"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Rhythm"
                        android:textColor="#847972"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navResources"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/imgNavResources"
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:alpha="0.78"
                        android:contentDescription="Resources"
                        android:src="@drawable/outline_fertile_24" />

                    <TextView
                        android:id="@+id/tvNavResources"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Calm Tools"
                        android:textColor="#847972"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ================= TREE RING OVERLAY (Hidden) ================= -->
        <FrameLayout
            android:id="@+id/treeRingOverlayHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <View
                android:id="@+id/treeRingOverlayScrim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:alpha="0.0"
                android:clickable="true"
                android:focusable="true"
                android:importantForAccessibility="no" />

            <com.aninaw.TreeRingView
                android:id="@+id/treeRingOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/treeRingFocusLayer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:alpha="0.0"
                android:visibility="gone"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no" />

            <FrameLayout
                android:id="@+id/treeRingHintOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="90dp">

                        <View
                            android:id="@+id/gesturePulse"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:alpha="0.10" />

                        <View
                            android:id="@+id/fingerLeft"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:translationX="-16dp"
                            android:translationY="12dp"
                            android:rotation="-24"
                            android:alpha="0.92" />

                        <View
                            android:id="@+id/fingerRight"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:translationX="16dp"
                            android:translationY="-12dp"
                            android:rotation="24"
                            android:alpha="0.92" />
                    </FrameLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#55FFFFFF">

                        <TextView
                            android:id="@+id/treeRingHintText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:maxWidth="260dp"
                            android:text="Pinch to zoom • Drag • Two fingers to rotate"
                            android:textSize="12sp"
                            android:textColor="#2E2621"
                            android:alpha="0.92"
                            android:gravity="center"
                            android:includeFontPadding="false" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </FrameLayout>

        </FrameLayout>

        <include
            layout="@layout/view_progress_tree_intro" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= DRAWER ================= -->
    <FrameLayout
        android:id="@+id/drawerContainer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FAF9F6">

        <include layout="@layout/drawer_content" />
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>
