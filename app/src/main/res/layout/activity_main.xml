<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home">

        <!-- Subtle Sunrays -->
        <ImageView
            android:id="@+id/ivSunRays"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:src="@drawable/ic_sunrays"
            android:scaleType="fitXY"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/sceneCanvas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <!-- HEADER: Menu & Greeting -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/btnMenu"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="24dp"
                        android:alpha="0.9"
                        android:background="@drawable/bg_menu_pill"
                        android:clickable="true"
                        android:contentDescription="Menu"
                        android:focusable="true"
                        android:padding="12dp"
                        android:src="@drawable/ic_menu"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/greetingGroup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginEnd="24dp"
                        android:alpha="1"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:importantForAccessibility="yes"
                        android:padding="12dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btnMenu">

                        <TextView
                            android:id="@+id/textTimeGreeting"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/source_sans_regular"
                            android:gravity="start"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.0"
                            android:text="Good afternoon."
                            android:textAlignment="viewStart"
                            android:textColor="@color/aninaw_text_primary"
                            android:textSize="26sp"
                            android:lineSpacingExtra="2dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvDayCounter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:alpha="0.72"
                            android:text="Day 1"
                            android:letterSpacing="0.06"
                            android:textColor="@color/aninaw_text_secondary"
                            android:textSize="12sp"
                            android:includeFontPadding="false"
                            app:layout_constraintStart_toStartOf="@id/textTimeGreeting"
                            app:layout_constraintTop_toBottomOf="@id/textTimeGreeting" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- TREE HOLDER (Big Size) -->
                <FrameLayout
                    android:id="@+id/treeHolderCard"
                    android:layout_width="match_parent"
                    android:layout_height="440dp"
                    android:layout_marginTop="10dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Glow behind tree -->
                    <View
                        android:layout_width="380dp"
                        android:layout_height="380dp"
                        android:background="@drawable/bg_tree_glow"
                        android:layout_gravity="center"
                        android:alpha="0.8" />

                    <!-- Text at the top -->
                    <TextView
                        android:id="@+id/tvTopPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="24dp"
                        android:alpha="0.86"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:includeFontPadding="false"
                        android:breakStrategy="balanced"
                        android:hyphenationFrequency="full"
                        android:justificationMode="inter_word"
                        android:lineSpacingExtra="2dp"
                        android:text=""
                        android:textColor="@color/aninaw_text_secondary"
                        android:textSize="16sp"
                        android:textStyle="italic" />

                    <!-- The Tree -->
                    <com.aninaw.views.HybridTreeView
                        android:id="@+id/hybridTreeView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/tvTreeNarrative"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_marginBottom="40dp"
                        android:alpha="0.86"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:paddingHorizontal="24dp"
                        android:text=""
                        android:textAlignment="center"
                        android:textColor="@color/aninaw_text_secondary"
                        android:textSize="14sp" />

                </FrameLayout>

                <!-- LIWANAG GROUP (Below Tree) -->
                <FrameLayout
                    android:id="@+id/liwanagGroup"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="-40dp"
                    android:layout_marginStart="20dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/bubbleGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardLiwanagBubble"
                        android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="@color/aninaw_frost"
                            app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:cardUseCompatPadding="true"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                android:id="@+id/textLiwanagPrompt"
                            android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                            android:gravity="start"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:maxWidth="320dp"
                            android:breakStrategy="balanced"
                            android:hyphenationFrequency="full"
                            android:justificationMode="inter_word"
                            android:lineSpacingExtra="2dp"
                            android:includeFontPadding="false"
                                android:textColor="@color/aninaw_text_secondary"
                            android:textSize="14sp"
                            android:textAlignment="viewStart" />
                        </com.google.android.material.card.MaterialCardView>

                        <ImageView
                            android:id="@+id/bubbleTail"
                            android:layout_width="20dp"
                            android:layout_height="10dp"
                        android:layout_marginTop="-2dp"
                            android:src="@drawable/speech_bubble_tail"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/cardLiwanagBubble" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <FrameLayout
                        android:id="@+id/liwanagContainer"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="bottom|start"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <FrameLayout
                            android:id="@+id/liwanagPoseContainer"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clipChildren="false"
                            android:clipToPadding="false" />

                    </FrameLayout>

                </FrameLayout>

                </LinearLayout>

                <!-- NAVIGATION GRID (Scrollable) -->
                <LinearLayout
                    android:id="@+id/bottomNavPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-40dp"
                    android:padding="16dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical">

                    <!-- ROW 1: Check-in | Rhythm -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- CHECK-IN -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tilePause"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:clipToOutline="true"
                            android:stateListAnimator="@animator/press_scale_card"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:cardPreventCornerOverlap="false"
                            app:strokeWidth="0dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/tile_checkin_bg"
                                android:padding="16dp">

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_gravity="top|end"
                                    android:src="@drawable/love"
                                    android:alpha="1.0" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|start"
                                    android:text="Calm Tools"
                                    android:textColor="#3E2723"
                                    android:textSize="18sp"
                                    android:textStyle="bold"/>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- RHYTHM -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tileRhythm"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:clipToOutline="true"
                            android:stateListAnimator="@animator/press_scale_card"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:cardPreventCornerOverlap="false"
                            app:strokeWidth="0dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/tile_rhythm_bg"
                                android:padding="16dp">

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_gravity="top|end"
                                    android:src="@drawable/shy"
                                    android:alpha="1.0" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Rhythm"
                                    android:textColor="#616161"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:layout_gravity="bottom|start" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- ROW 2: My Routines | Your Tree Ring -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- MY ROUTINES (formerly Systems) -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tileSystems"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:clipToOutline="true"
                            android:stateListAnimator="@animator/press_scale_card"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:cardPreventCornerOverlap="false"
                            app:strokeWidth="0dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/tile_my_rhythms"
                                android:padding="16dp">

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_gravity="top|end"
                                    android:src="@drawable/happy"
                                    android:alpha="1.0" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="My\nroutines"
                                    android:textColor="#4A148C"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:layout_gravity="bottom|start" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- YOUR TREE RING (formerly Analyze Growth) -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tileTreeRing"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:clipToOutline="true"
                            android:stateListAnimator="@animator/press_scale_card"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:cardPreventCornerOverlap="false"
                            app:strokeWidth="0dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/tile_growth_bg"
                                android:padding="16dp">

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_gravity="top|end"
                                    android:src="@drawable/smile"
                                    android:alpha="1.0" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Your tree\nring"
                                    android:textColor="#880E4F"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:layout_gravity="bottom|start" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- ROW 4: My Roots (Full Width) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileRoots"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:clipToOutline="true"
                        android:stateListAnimator="@animator/press_scale_card"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:cardPreventCornerOverlap="false"
                        app:strokeWidth="0dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/tile_roots_bg"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center_vertical|end"
                                android:src="@drawable/mature_tree"
                                android:alpha="1.0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Roots"
                                android:textColor="#E65100"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_gravity="center_vertical|start" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- ================= TREE RING OVERLAY (Hidden) ================= -->
        <FrameLayout
            android:id="@+id/treeRingOverlayHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <View
                android:id="@+id/treeRingOverlayScrim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:alpha="0.0"
                android:clickable="true"
                android:focusable="true"
                android:importantForAccessibility="no" />

            <com.aninaw.TreeRingView
                android:id="@+id/treeRingOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/treeRingFocusLayer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:alpha="0.0"
                android:visibility="gone"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no" />

            <FrameLayout
                android:id="@+id/treeRingHintOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="90dp">

                        <View
                            android:id="@+id/gesturePulse"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:alpha="0.10" />

                        <View
                            android:id="@+id/fingerLeft"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:translationX="-16dp"
                            android:translationY="12dp"
                            android:rotation="-24"
                            android:alpha="0.92" />

                        <View
                            android:id="@+id/fingerRight"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:translationX="16dp"
                            android:translationY="-12dp"
                            android:rotation="24"
                            android:alpha="0.92" />
                    </FrameLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#55FFFFFF">

                        <TextView
                            android:id="@+id/treeRingHintText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:maxWidth="260dp"
                            android:text="Pinch to zoom • Drag • Two fingers to rotate"
                            android:textSize="12sp"
                            android:textColor="#2E2621"
                            android:alpha="0.92"
                            android:gravity="center"
                            android:includeFontPadding="false" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </FrameLayout>

        </FrameLayout>

        <include
            layout="@layout/view_progress_tree_intro" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= DRAWER ================= -->
    <FrameLayout
        android:id="@+id/drawerContainer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FAF9F6">

        <include layout="@layout/drawer_content" />
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>
