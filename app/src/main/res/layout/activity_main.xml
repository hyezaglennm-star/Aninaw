<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/sceneCanvas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <!-- HEADER: Menu & Greeting -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/btnMenu"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="24dp"
                        android:alpha="0.9"
                        android:background="@drawable/bg_menu_pill"
                        android:clickable="true"
                        android:contentDescription="Menu"
                        android:focusable="true"
                        android:padding="12dp"
                        android:src="@drawable/ic_menu"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/greetingGroup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginEnd="24dp"
                        android:alpha="1"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:importantForAccessibility="yes"
                        android:padding="12dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btnMenu">

                        <TextView
                            android:id="@+id/textTimeGreeting"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/source_sans_regular"
                            android:gravity="start"
                            android:includeFontPadding="false"
                            android:letterSpacing="0.0"
                            android:text="Good afternoon."
                            android:textAlignment="viewStart"
                            android:textColor="@color/aninaw_text_primary"
                            android:textSize="26sp"
                            android:lineSpacingExtra="2dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvDayCounter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:alpha="0.72"
                            android:text="Day 1"
                            android:letterSpacing="0.06"
                            android:textColor="@color/aninaw_text_secondary"
                            android:textSize="12sp"
                            android:includeFontPadding="false"
                            app:layout_constraintStart_toStartOf="@id/textTimeGreeting"
                            app:layout_constraintTop_toBottomOf="@id/textTimeGreeting" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- TREE HOLDER (Big Size) -->
                <FrameLayout
                    android:id="@+id/treeHolderCard"
                    android:layout_width="match_parent"
                    android:layout_height="440dp"
                    android:layout_marginTop="10dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Glow behind tree -->
                    <View
                        android:layout_width="380dp"
                        android:layout_height="380dp"
                        android:background="@drawable/bg_tree_glow"
                        android:layout_gravity="center"
                        android:alpha="0.8" />

                    <!-- Text at the top -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="24dp"
                        android:alpha="0.86"
                        android:text="No catching up. Just one small check-in"
                        android:textColor="@color/aninaw_text_secondary"
                        android:textSize="18sp"
                        android:textStyle="italic" />

                    <!-- The Tree -->
                    <com.aninaw.views.HybridTreeView
                        android:id="@+id/hybridTreeView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/tvTreeNarrative"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_marginBottom="40dp"
                        android:alpha="0.86"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:paddingHorizontal="24dp"
                        android:text=""
                        android:textAlignment="center"
                        android:textColor="@color/aninaw_text_secondary"
                        android:textSize="14sp" />

                </FrameLayout>

                <!-- LIWANAG GROUP (Below Tree) -->
                <FrameLayout
                    android:id="@+id/liwanagGroup"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginTop="-60dp"
                    android:layout_marginStart="20dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/bubbleGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardLiwanagBubble"
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/aninaw_frost"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                android:id="@+id/textLiwanagPrompt"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:padding="12dp"
                                android:textColor="@color/aninaw_text_secondary"
                                android:textSize="12sp"
                                android:textStyle="italic" />
                        </com.google.android.material.card.MaterialCardView>

                        <ImageView
                            android:id="@+id/bubbleTail"
                            android:layout_width="20dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="-1dp"
                            android:src="@drawable/speech_bubble_tail"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/cardLiwanagBubble" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <FrameLayout
                        android:id="@+id/liwanagContainer"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="bottom|start"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <FrameLayout
                            android:id="@+id/liwanagPoseContainer"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clipChildren="false"
                            android:clipToPadding="false" />

                    </FrameLayout>

                </FrameLayout>

                </LinearLayout>

                <!-- NAVIGATION GRID (Scrollable) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/bottomNavPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-40dp"
                    android:padding="16dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- CHECK-IN -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tilePause"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:clipToOutline="true"
                        android:stateListAnimator="@animator/press_scale_card"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:cardPreventCornerOverlap="false"
                        app:strokeWidth="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tileRhythm"
                        app:layout_constraintHorizontal_chainStyle="spread">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/tile_checkin_bg"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_gravity="top|end"
                                android:src="@drawable/love"
                                android:alpha="1.0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:text="Check-in"
                                android:textColor="@color/text_home_checkin"
                                android:textSize="20sp"
                                android:textStyle="bold"/>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- RHYTHM -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileRhythm"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:clipToOutline="true"
                        android:stateListAnimator="@animator/press_scale_card"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:cardPreventCornerOverlap="false"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tilePause"
                        app:layout_constraintEnd_toEndOf="parent">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/tile_rhythm_bg"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_gravity="top|end"
                                android:src="@drawable/shy"
                                android:alpha="1.0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rhythm"
                                android:textColor="@color/text_home_rhythm"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_gravity="bottom|start" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ANALYZE YOUR GROWTH -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileTreeRing"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:clipToOutline="true"
                        android:stateListAnimator="@animator/press_scale_card"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:cardPreventCornerOverlap="false"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:layout_constraintTop_toBottomOf="@id/tilePause"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tileSystems"
                        app:layout_constraintHorizontal_chainStyle="spread">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/tile_growth_bg"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_gravity="top|end"
                                android:src="@drawable/smile"
                                android:alpha="1.0" />     

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Analyze\nGrowth"
                                android:textColor="@color/text_home_growth"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_gravity="bottom|start" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- MY SYSTEMS -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileSystems"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:clipToOutline="true"
                        android:stateListAnimator="@animator/press_scale_card"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:cardPreventCornerOverlap="false"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:layout_constraintTop_toBottomOf="@id/tileRhythm"
                        app:layout_constraintStart_toEndOf="@id/tileTreeRing"
                        app:layout_constraintEnd_toEndOf="parent">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/tile_my_rhythms"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_gravity="top|end"
                                android:src="@drawable/happy"
                                android:alpha="1.0" />      

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My\nSystems"
                                android:textColor="@color/text_home_systems"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_gravity="bottom|start" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- ================= TREE RING OVERLAY (Hidden) ================= -->
        <FrameLayout
            android:id="@+id/treeRingOverlayHost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <View
                android:id="@+id/treeRingOverlayScrim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:alpha="0.0"
                android:clickable="true"
                android:focusable="true"
                android:importantForAccessibility="no" />

            <com.aninaw.TreeRingView
                android:id="@+id/treeRingOverlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:id="@+id/treeRingFocusLayer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                android:alpha="0.0"
                android:visibility="gone"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no" />

            <FrameLayout
                android:id="@+id/treeRingHintOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:alpha="0"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="90dp">

                        <View
                            android:id="@+id/gesturePulse"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:alpha="0.10" />

                        <View
                            android:id="@+id/fingerLeft"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:translationX="-16dp"
                            android:translationY="12dp"
                            android:rotation="-24"
                            android:alpha="0.92" />

                        <View
                            android:id="@+id/fingerRight"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:background="@drawable/gesture_finger_dot"
                            android:translationX="16dp"
                            android:translationY="-12dp"
                            android:rotation="24"
                            android:alpha="0.92" />
                    </FrameLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#55FFFFFF">

                        <TextView
                            android:id="@+id/treeRingHintText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:maxWidth="260dp"
                            android:text="Pinch to zoom • Drag • Two fingers to rotate"
                            android:textSize="12sp"
                            android:textColor="#2E2621"
                            android:alpha="0.92"
                            android:gravity="center"
                            android:includeFontPadding="false" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </FrameLayout>

        </FrameLayout>

        <include
            layout="@layout/view_progress_tree_intro" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= DRAWER ================= -->
    <FrameLayout
        android:id="@+id/drawerContainer"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FAF9F6">

        <include layout="@layout/drawer_content" />
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>
