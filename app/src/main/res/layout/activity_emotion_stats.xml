<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aninaw_bg_top">

    <!-- HEADER -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:src="@drawable/ic_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Journal"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/aninaw_text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack" />

    <ImageView
        android:id="@+id/btnMenu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:src="@drawable/ic_menu"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- BIG NUMBER -->
    <TextView
        android:id="@+id/tvCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="420"
        android:textSize="56sp"
        android:textStyle="bold"
        android:textColor="@color/aninaw_text_primary"
        android:layout_marginTop="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Celebrate what made you smile today."
        android:textSize="14sp"
        android:textColor="@color/aninaw_text_secondary"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCount" />

    <!-- EMOTIONS CHART CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardChart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/tvCount"
        app:layout_constraintBottom_toTopOf="@id/btnCreate">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emotions"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/aninaw_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Here are four core emotions for your journal"
                android:textSize="12sp"
                android:textColor="@color/aninaw_text_secondary"
                android:layout_marginTop="4dp" />

            <!-- BAR CHART PLACEHOLDER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginTop="24dp">

                <!-- HAPPY -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="bottom|center_horizontal"
                    android:orientation="vertical">
                    
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_bar_track"
                        android:clipChildren="true">
                        
                        <View
                            android:id="@+id/barHappy"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_gravity="bottom"
                            android:background="@drawable/bg_bar_happy" />
                            
                        <TextView
                            android:id="@+id/textHappyPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="48%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#3E2723"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:elevation="4dp" />
                    </FrameLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Happy"
                        android:layout_marginTop="8dp"
                        android:textSize="12sp"
                        android:textColor="@color/aninaw_text_primary" />
                </LinearLayout>

                <!-- SAD -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="bottom|center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_bar_track"
                        android:clipChildren="true">

                        <View
                            android:id="@+id/barSad"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_gravity="bottom"
                            android:background="@drawable/bg_bar_sad" />

                        <TextView
                            android:id="@+id/textSadPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="33%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:elevation="4dp" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sad"
                        android:layout_marginTop="8dp"
                        android:textSize="12sp"
                        android:textColor="@color/aninaw_text_primary" />
                </LinearLayout>

                <!-- CALM -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="bottom|center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_bar_track"
                        android:clipChildren="true">

                        <View
                            android:id="@+id/barCalm"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_gravity="bottom"
                            android:background="@drawable/bg_bar_calm" />

                        <TextView
                            android:id="@+id/textCalmPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="27%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:elevation="4dp" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calm"
                        android:layout_marginTop="8dp"
                        android:textSize="12sp"
                        android:textColor="@color/aninaw_text_primary" />
                </LinearLayout>

                <!-- ANXIOUS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="bottom|center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_bar_track"
                        android:clipChildren="true">

                        <View
                            android:id="@+id/barAnxious"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_gravity="bottom"
                            android:background="@drawable/bg_bar_anxious" />

                        <TextView
                            android:id="@+id/textAnxiousPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="40%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:elevation="4dp" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anxious"
                        android:layout_marginTop="8dp"
                        android:textSize="12sp"
                        android:textColor="@color/aninaw_text_primary" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreate"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="24dp"
        android:text="Create a New Journal"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#3E2723"
        app:backgroundTint="#FFB300"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
