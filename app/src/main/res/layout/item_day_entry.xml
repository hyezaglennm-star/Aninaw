<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Tree-ring separator line -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:src="@drawable/tree_ring_line"
        android:scaleType="fitXY"
        android:alpha="0.8" />

    <!-- Content panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvItemDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="March 9 • Today"
            android:textColor="#3A312B"
            android:textSize="17sp"
            android:fontFamily="@font/cormorant_garamond_medium" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <View
                android:id="@+id/viewMoodDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_mood"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvItemMood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Okay"
                android:textColor="#5B5049"
                android:textSize="15sp"
                android:fontFamily="@font/inter_regular" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvItemMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Checked in 7:12 PM"
            android:textColor="#7A7068"
            android:textSize="13sp"
            android:fontFamily="@font/inter_regular" />

        <TextView
            android:id="@+id/tvItemNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="You stayed present today."
            android:textColor="#6A5F57"
            android:textSize="14sp"
            android:fontFamily="@font/cormorant_garamond_medium" />

        <!-- Tags line (e.g. Used: Breathing • Quick stretch) -->
        <TextView
            android:id="@+id/tvItemTags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_tag_pill"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Used: Breathing • Quick stretch"
            android:textColor="#5D544D"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
