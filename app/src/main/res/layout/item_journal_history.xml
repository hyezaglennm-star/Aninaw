<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#F7F1EA"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#14FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvEntryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cormorant_garamond_semibold"
            android:text="Morning Reflection"
            android:textColor="@color/aninaw_text_primary"
            android:textSize="21sp" />

        <TextView
            android:id="@+id/tvEntryMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter_regular"
            android:text="March 13, 2026 • 7:12 AM"
            android:textColor="@color/aninaw_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvEntryPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingExtra="3dp"
            android:maxLines="3"
            android:text="A short preview of the journal entry appears here."
            android:textColor="@color/aninaw_text_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEntryType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_journal_type_chip"
                android:fontFamily="@font/inter_regular"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="Morning"
                android:textColor="@color/aninaw_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvMood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_journal_type_chip"
                android:fontFamily="@font/inter_regular"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="Calm"
                android:textColor="@color/aninaw_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>