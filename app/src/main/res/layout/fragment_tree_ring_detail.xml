<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aninaw_bg_top"
    android:clickable="true"
    android:focusable="true">

    <!-- Background Image (Centered) -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:src="@drawable/ring_bg"
        android:scaleType="fitCenter"
        android:alpha="0.25" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingHorizontal="16dp">

        <!-- Header with Back Button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="?selectableItemBackgroundBorderless"
                android:layout_gravity="center_vertical|start"
                app:tint="#4E342E" />

        </FrameLayout>

        <!-- Search Section -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_tile_soft"
            android:hint="Search logs..."
            android:textColor="#4E342E"
            android:textColorHint="#8D7F75"
            android:paddingHorizontal="16dp"
            android:drawableStart="@drawable/ic_menu"
            android:drawableTint="#8D7F75"
            android:drawablePadding="12dp"
            android:layout_marginBottom="16dp"
            android:inputType="text"/>

        <!-- Log Field (Scrollable) -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/tvEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="You didn't check-in on this day."
                    android:textSize="18sp"
                    android:textColor="#8D7F75"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone"
                    tools:visibility="visible"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_tree_ring_log"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Overlay Grid of Days (initially visible) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTreeRingMemories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="80dp"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        android:visibility="gone"
        tools:visibility="visible" />

</FrameLayout>
