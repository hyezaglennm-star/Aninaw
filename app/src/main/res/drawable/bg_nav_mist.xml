<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">


    <!-- Mist that is strongest at the bottom, fading upward -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#D9F3EFE8"
                android:centerColor="#8CF3EFE8"
                android:endColor="#00F3EFE8"/>
        </shape>
    </item>

    <!-- Subtle top hairline separator (1dp), not a chunky shadow -->
    <item android:top="0dp">
        <shape android:shape="rectangle">
            <size android:height="1dp" />
            <solid android:color="#14000000" />
        </shape>
    </item>


</layer-list>
