<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base vertical gradient -->
    <item>
        <shape>
            <gradient
                android:startColor="#86A884"
                android:endColor="#6F8F6D"
                android:angle="270"/>
        </shape>
    </item>

    <!-- Soft radial center glow -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="0.5"
                android:centerY="0.3"
                android:startColor="#15FFFFFF"
                android:endColor="@android:color/transparent"/>
        </shape>
    </item>

</layer-list>
