<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: Bright Sunshine Yellow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:startColor="#FFEA00"
                android:centerColor="#FFD600"
                android:endColor="#FBC02D" />
        </shape>
    </item>

    <!-- Inner highlight -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <gradient
                android:angle="270"
                android:startColor="#44FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>