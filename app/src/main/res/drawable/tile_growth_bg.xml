<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: soft sage / growth -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:startColor="#E6F4ED"
                android:centerColor="#DDEFE6"
                android:endColor="#D2E7DC" />
        </shape>
    </item>

    <!-- Inner highlight -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <gradient
                android:angle="270"
                android:startColor="#55FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Soft stroke -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#1A203328" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>