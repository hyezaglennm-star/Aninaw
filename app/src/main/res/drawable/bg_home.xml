<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/aninaw_bg_top"
                android:endColor="@color/aninaw_bg_bottom"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="0.5"
                android:centerY="0.35"
                android:startColor="#10FFFFFF"
                android:endColor="#00FFFFFF"/>
        </shape>
    </item>

</layer-list>