<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="400dp"
    android:height="400dp"
    android:viewportWidth="100"
    android:viewportHeight="100">
    <!-- Strong, messy sunrays from left to right (diagonal) -->
    <!-- Main broad beam -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.2"
        android:pathData="M-10,0 L110,60 L110,100 L-10,40 Z" />
    <!-- Sharp, strong beam 1 -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.4"
        android:pathData="M-5,-5 L80,105 L50,105 L-5,10 Z" />
    <!-- Sharp, strong beam 2 -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.3"
        android:pathData="M0,20 L105,80 L105,50 L0,10 Z" />
    <!-- Extra messy streak -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.25"
        android:pathData="M-20,30 L120,90 L120,110 L-20,60 Z" />
    <!-- Bright core streak -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.5"
        android:pathData="M-10,10 L90,90 L70,90 L-10,25 Z" />
</vector>
