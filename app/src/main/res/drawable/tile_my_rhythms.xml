<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: soft pearl-lavender mist -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:startColor="#F1F2F6"
                android:centerColor="#E8E9F0"
                android:endColor="#DEE0EA" />
        </shape>
    </item>

    <!-- Subtle inner highlight -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <gradient
                android:angle="270"
                android:startColor="#55FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Hairline stroke -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#1A2A2F3A" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>