<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <solid android:color="#20000000"/>
        </shape>
    </item>

    <!-- actual card -->
    <item android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <solid android:color="#FFEEEE"/>
        </shape>
    </item>

</layer-list>