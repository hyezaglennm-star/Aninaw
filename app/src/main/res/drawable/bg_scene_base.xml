<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Sky gradient -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#E8F1F6"
                android:centerColor="#F6F9FC"
                android:endColor="#FAF7F2"/>
        </shape>
    </item>

    <!-- Top radial light -->
    <item>
        <shape>
            <gradient
                android:type="radial"
                android:gradientRadius="700dp"
                android:centerX="0.5"
                android:centerY="0.0"
                android:startColor="#33FFFFFF"
                android:endColor="@android:color/transparent"/>
        </shape>
    </item>

</layer-list>