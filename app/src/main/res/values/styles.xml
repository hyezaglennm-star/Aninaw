<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:app="http://schemas.android.com/apk/res-auto">

    <style name="ToolbarTitleSmall" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">@font/source_sans</item> <!-- optional -->
    </style>

    <!-- Calm card -->
    <style name="CalmCard">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">#F6F4EF</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#E3E0D9</item>
    </style>

    <!-- Card inner spacing -->
    <style name="CalmCardInner">
        <item name="android:orientation">vertical</item>
        <item name="android:padding">20dp</item>
    </style>

    <!-- Title -->
    <style name="CalmCardTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#3E3E39</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Subtitle -->
    <style name="CalmCardSub">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#7E7A73</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>

    <style name="CalmCardInnerRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">18dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="CalmCardMeta">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#8C877F</item>
        <item name="android:layout_marginTop">6dp</item>
    </style>

    <style name="PracticePathTitle">
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/aninaw_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PracticePathSubtitle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/aninaw_text_secondary</item>
    </style>

    <style name="SessionTileNumber">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/aninaw_text_primary</item>
        <item name="android:textStyle">normal</item>
    </style>

        <style name="CalmPrimaryButton" parent="Widget.MaterialComponents.Button">
            <item name="android:textAllCaps">false</item>
            <item name="android:textColor">#FFFFFF</item>
            <item name="backgroundTint">#7A9B76</item>
            <item name="cornerRadius">18dp</item>
            <item name="android:insetLeft">0dp</item>
            <item name="android:insetRight">0dp</item>
            <item name="android:insetTop">0dp</item>
            <item name="android:insetBottom">0dp</item>
            <item name="android:paddingLeft">20dp</item>
            <item name="android:paddingRight">20dp</item>
            <item name="android:paddingTop">12dp</item>
            <item name="android:paddingBottom">12dp</item>
        </style>

        <style name="CalmSecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
            <item name="android:textAllCaps">false</item>
            <item name="android:textColor">#5F6F5B</item>
            <item name="strokeColor">#B7C6B2</item>
            <item name="strokeWidth">1dp</item>
            <item name="cornerRadius">18dp</item>
            <item name="backgroundTint">#00FFFFFF</item>
            <item name="android:insetLeft">0dp</item>
            <item name="android:insetRight">0dp</item>
            <item name="android:insetTop">0dp</item>
            <item name="android:insetBottom">0dp</item>
            <item name="android:paddingLeft">20dp</item>
            <item name="android:paddingRight">20dp</item>
            <item name="android:paddingTop">12dp</item>
            <item name="android:paddingBottom">12dp</item>
        </style>

    <style name="SecondaryButtonStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">#6F7F73</item>
        <item name="strokeColor">#C9D6CC</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">#F7F5F1</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="PrimaryButtonStyle" parent="Widget.Material3.Button">
        <item name="android:textColor">@android:color/white</item>
        <item name="backgroundTint">#9CB7A8</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>


</resources>